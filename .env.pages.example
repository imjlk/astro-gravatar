# Copy the values you need into `.env.local` or export them in your shell before
# running the Cloudflare Pages scripts.

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT_NAME=astro-gravatar-and-guide

# Optional. Used by `bun run pages:deploy:preview`.
CLOUDFLARE_PAGES_BRANCH=

# Optional. When omitted, analytics remains fully disabled.
PUBLIC_GA_MEASUREMENT_ID=
