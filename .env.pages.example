# Copy these into `.env.local` for local use, or mirror them into your CI
# secrets/variables before running the Cloudflare Pages scripts.
#
# Required for direct upload deployment:
# - `CLOUDFLARE_ACCOUNT_ID`: Cloudflare account ID for the target Pages project
# - `CLOUDFLARE_API_TOKEN`: API token with Cloudflare Pages edit access
# - `CLOUDFLARE_PAGES_PROJECT_NAME`: exact Pages project name

CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_PAGES_PROJECT_NAME=astro-gravatar-and-guide

# Optional. Used by `bun run pages:deploy:preview`.
# Leave empty to fall back to the current git branch name.
CLOUDFLARE_PAGES_BRANCH=preview

# Optional. Used by `bun run pages:dev`.
CLOUDFLARE_PAGES_DEV_PORT=8788

# Optional. When omitted, analytics remains fully disabled.
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
